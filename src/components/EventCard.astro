---
import type { AicEvent } from '../lib/events';
import VotingBadge from './VotingBadge.astro';
import { isVotingOpen } from '../lib/events';

interface Props {
  event: AicEvent;
}
const { event } = Astro.props;

const votingOpen = isVotingOpen(event);
const dateFormatted = new Date(event.date).toLocaleDateString('de-AT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a
  href={`/${event.slug}`}
  class:list={[
    'group block rounded-2xl border bg-white p-6 sm:p-8 card-hover transition-all',
    event.featured
      ? 'border-[var(--orange)] shadow-[0_0_0_1px_var(--orange),0_4px_24px_var(--orange-glow)]'
      : 'border-[var(--mid-gray)] hover:border-[var(--orange)]',
  ]}
>
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div class="flex-1 min-w-0">
      {event.featured && (
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--orange)] mb-2 block">
          Aktuell
        </span>
      )}
      <div class="flex items-start justify-between gap-3">
        <h2 class="text-xl sm:text-2xl font-bold text-[var(--dark-2)] group-hover:text-[var(--orange)] transition-colors">
          {event.title}
        </h2>
        <div class="shrink-0 sm:hidden">
          <VotingBadge votingOpen={votingOpen} />
        </div>
      </div>

      <p class="mt-2 text-sm text-[var(--text-muted)]">
        {[dateFormatted, event.location, event.participantCount ? `${event.participantCount} Teilnehmer` : null]
          .filter(Boolean).join(' · ')}
      </p>

      {event.description && (
        <p class="mt-3 text-sm text-[var(--dark)] leading-relaxed line-clamp-2">
          {event.description}
        </p>
      )}

      <!-- Mobile-only bottom row -->
      <div class="flex items-center justify-between mt-3 sm:hidden">
        <span class="text-sm text-[var(--text-muted)]">
          <span class="font-black text-[var(--orange)] text-lg">{event.projects.length}</span>
          {' '}{event.projects.length === 1 ? 'Prototyp' : 'Prototypen'}
        </span>
        <span class="flex items-center gap-1 text-sm font-medium text-[var(--blue)]">
          Ansehen
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </div>

    <div class="hidden sm:flex sm:flex-col sm:items-end sm:gap-3 shrink-0">
      <VotingBadge votingOpen={votingOpen} />
      <div class="text-center sm:text-right">
        <div class="text-2xl font-black text-[var(--orange)]">
          {event.projects.length}
        </div>
        <div class="text-xs text-[var(--text-muted)] uppercase tracking-wide font-medium">
          {event.projects.length === 1 ? 'Prototyp' : 'Prototypen'}
        </div>
      </div>
      <span class="flex items-center gap-1 text-sm font-medium text-[var(--blue)] group-hover:translate-x-1 transition-transform">
        Ansehen
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>
</a>
