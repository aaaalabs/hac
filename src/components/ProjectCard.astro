---
import type { Project } from '../lib/events';
import ToolBadge from './ToolBadge.astro';

interface Props {
  project: Project;
  initialVoteCount: number;
  hasVoted: boolean;
  votingOpen: boolean;
  eventSlug: string;
  index: number;
}

const { project, initialVoteCount, hasVoted, votingOpen, eventSlug, index } = Astro.props;

const screenshotFallback = `https://placehold.co/1200x750/F97316/FFFFFF?text=${encodeURIComponent(project.name)}`;
---

<article
  class="project-card bg-white rounded-2xl border border-[var(--mid-gray)] overflow-hidden card-hover animate-fade-in-up flex flex-col"
  data-votes={initialVoteCount}
  style={`animation-delay: ${index * 50}ms;`}
>
  <!-- Screenshot -->
  <div class="relative aspect-[16/10] bg-[var(--light-gray)] overflow-hidden">
    <img
      src={project.screenshotPath}
      alt={`Screenshot von ${project.name}`}
      loading="lazy"
      class="w-full h-full object-cover"
      onerror={`this.src='${screenshotFallback}'`}
    />
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <div class="flex-1">
      <div class="flex items-start justify-between gap-2 mb-1">
        <h3 class="text-base font-bold text-[var(--dark-2)] leading-tight">
          {project.name}
        </h3>
        <ToolBadge tool={project.tool} />
      </div>

      <p class="text-sm text-[var(--text-muted)] leading-relaxed line-clamp-2">
        {project.description}
      </p>

      <p class="mt-2 text-xs text-[var(--text-muted)]">
        {project.team.join(', ')}
      </p>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3 pt-2 border-t border-[var(--light-gray)]">
      <!-- VoteButton slot — React island injected by parent -->
      <slot name="vote-button" />

      <a
        href={project.appUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 text-center px-3 py-2 rounded-lg border-2 border-[var(--mid-gray)] text-sm font-semibold text-[var(--dark)] hover:border-[var(--blue)] hover:text-[var(--blue)] transition-colors min-h-[44px] flex items-center justify-center"
      >
        App öffnen ↗
      </a>
    </div>
  </div>
</article>
