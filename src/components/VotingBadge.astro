---
interface Props {
  votingOpen: boolean;
  isLive?: boolean;
}
const { votingOpen, isLive = false } = Astro.props;
---

{isLive && (
  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold text-white"
        style="background: var(--orange);">
    <span class="relative flex h-2 w-2">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75"
            style="background: var(--orange-accent);"></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
    </span>
    Live
  </span>
)}

{!isLive && votingOpen && (
  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold text-white"
        style="background: var(--green);">
    <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
    Voting offen
  </span>
)}

{!isLive && !votingOpen && (
  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold text-[var(--text-muted)]"
        style="background: var(--mid-gray);">
    <span class="h-1.5 w-1.5 rounded-full" style="background: var(--text-muted);"></span>
    Voting geschlossen
  </span>
)}
