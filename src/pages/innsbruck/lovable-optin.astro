---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const EVENTS: Record<string, { title: string; date: string }> = {
  'buildathon-zero':  { title: 'Buildathon Zero',  date: '6. März 2026' },
  'ideen-fuer-tirol': { title: 'Ideen für Tirol',  date: '24. März 2026' },
};

const eventSlug = Astro.url.searchParams.get('event') ?? '';
const event = EVENTS[eventSlug];
---

<BaseLayout
  title={event ? `Lovable Credits – ${event.title}` : 'Lovable Credits'}
  description={event ? `Trag dich ein und sichere dir 100 kostenlose Lovable Credits für den Buildathon am ${event.date}.` : ''}
  noindex={true}
>
  <main id="main-content" class="lovable-bg min-h-screen flex flex-col items-center justify-center px-4 py-12">

    {!event ? (
      <!-- Error Card -->
      <div class="glass-card w-full max-w-lg rounded-2xl overflow-hidden px-8 py-12 text-center">
        <div class="text-5xl mb-4">⚠️</div>
        <h1 class="text-xl font-bold mb-3" style="color: #ffffff;">Ungültiger Link</h1>
        <p style="color: rgba(255,255,255,0.6);" class="leading-relaxed">
          Bitte wende dich an den Veranstalter, um den korrekten Link zu erhalten.
        </p>
      </div>
    ) : (
      <!-- Card -->
      <div class="glass-card w-full max-w-lg rounded-2xl overflow-hidden">

        <!-- Header: Logos -->
        <div class="px-8 pt-8 pb-6 flex items-center justify-center gap-5">
          <!-- AIC Logo (orange — AIC brand, also echoes Lovable warm gradient) -->
          <a href="/" aria-label="AI Collective Innsbruck">
            <svg height="30" viewBox="0 0 700 844.38" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path fill="#F97316" d="M694.7,679.31l-149.94-137.92c-13.12-12.07-32.7-13.24-47.49-3.29-44.87,30.17-97.32,45.96-153.5,45.96-66.92,0-132.46-22.46-184.56-63.24C54.13,438.52,29.44,294.27,101.78,185.26c37.44-56.39,112.97-103.46,197.12-122.86,24.94-5.75,50.74-8.66,76.69-8.66,61.13,0,124.86,16.38,184.39,47.43l.31.16c16.09,9.03,31.38,19.42,45.5,30.9l11.09,9.01,3.33,2.7-3.16,2.9-93.9,86.38-1.93,1.78-2.32-1.23-9.26-4.92c-30.06-15.96-75.63-37.57-124.09-40.86-5.51-.37-11.1-.56-16.6-.56-28.53,0-57.1,4.97-83.76,15.21-23.25,8.93-55.5,24.02-70.53,44.86-3.12,4.32-4.69,10.14-2.68,15.07,2.36,5.79,9.07,8.84,15.32,8.74,10.28-.16,20.6-6.68,30.07-10.2,11.64-4.33,23.56-7.93,35.64-10.81,24.04-5.72,48.74-8.54,73.45-8.54,37.75,0,68.84,8.01,97.83,25.22,12.1,7.17,23.49,15.81,33.95,24.6,13.62,11.44,33.54,11.21,46.63-.83l149.97-137.96c6.75-6.21,6.88-16.82.31-23.2-13.34-12.95-27.49-25.04-42.26-36.07-13.29-9.92-27.33-19.25-41.72-27.72C539.11,23.37,454.31,0,372.39,0c-56.4,0-109.82,10.68-158.77,31.74C126.79,69.1,59.15,130.13,28.07,199.16,2.09,256.82-5.91,315.18,4.3,372.61c9.17,51.64,33.48,101.7,70.31,144.79,35.23,41.21,80.73,74.95,131.57,97.58,42.69,19.01,101.49,30.83,153.44,30.83,6.22-.07,12.33-.24,18.32-.52,47.63-2.8,91.56-16.68,130.58-41.23l9.53-6,2.4-1.51,2.09,1.92,97.19,89.4,3.4,3.12-3.78,2.65-12.69,8.89c-84.2,58.86-187.1,87.56-289.71,79.97-108.4-8.02-212.81-56.5-288.56-134.48-7.39-7.61-18.11-5.52-23.96.54-.31.32-.63.63-.92.98-.07.07-.13.15-.2.22-1.54,1.95-2.59,4.25-3.04,6.76-.52,2.92-.23,6.11,1.29,9.4.12.26.24.51.36.77,22.47,47.6,66.99,82.24,110.71,109.63,45.25,28.35,95.53,48.49,147.87,59.1,6.69,1.36,13.42,2.56,20.17,3.61.67.1,1.34.21,2.01.31,21.36,3.22,43.21,4.91,65.44,5,59.45-.25,122.27-13.82,181.31-37.43,62.22-24.88,120.24-60.87,165.52-104.32,6.22-5.97,6.54-15.3,1.16-21.69-.45-.54-.87-1.1-1.41-1.59Z"/>
            </svg>
          </a>

          <span style="color: rgba(255,255,255,0.3); font-size:1.25rem; font-weight:300;">×</span>

          <!-- Lovable Logo (white — as designed for dark backgrounds) -->
          <a href="https://lovable.dev" target="_blank" rel="noopener noreferrer" aria-label="Lovable">
          <svg viewBox="0 0 755 129" fill="none" xmlns="http://www.w3.org/2000/svg" style="height:24px;" color="#FCFBF8" aria-label="Lovable"><path fill="currentColor" d="M303.603 30.94c9.149 0 17.163 1.982 24.04 5.945 6.876 3.963 12.18 9.616 15.91 16.959 3.788 7.285 5.682 15.852 5.682 25.7 0 9.85-1.894 18.447-5.682 25.79-3.73 7.343-9.034 12.996-15.91 16.959-6.877 3.963-14.891 5.944-24.04 5.944-9.15 0-17.193-1.981-24.128-5.944-6.877-3.963-12.21-9.616-15.998-16.959-3.73-7.343-5.595-15.94-5.595-25.79 0-9.848 1.865-18.415 5.595-25.7 3.788-7.343 9.121-12.996 15.998-16.96 6.935-3.962 14.978-5.944 24.128-5.944Zm176.168 0c8.683 0 16.026 1.428 22.029 4.284 6.002 2.797 10.519 6.818 13.55 12.063 3.088 5.245 4.633 11.511 4.633 18.796v38.464c0 4.138.292 7.984.874 11.539.641 3.497 1.545 5.712 2.71 6.644v2.972H496.03c-.641-2.506-1.136-5.332-1.486-8.479-.116-1.04-.214-2.1-.298-3.178a32.537 32.537 0 0 1-2.149 2.828c-2.914 3.438-6.674 6.207-11.278 8.305-4.545 2.039-9.732 3.059-15.56 3.059-5.77 0-10.957-1.136-15.561-3.409-4.546-2.273-8.13-5.507-10.753-9.703-2.564-4.254-3.846-9.208-3.846-14.861 0-8.626 2.535-15.211 7.605-19.757 5.07-4.604 12.385-7.605 21.942-9.004l15.999-2.273c3.205-.467 5.74-1.05 7.605-1.749 1.865-.699 3.234-1.632 4.108-2.797.875-1.224 1.312-2.768 1.312-4.633 0-1.923-.524-3.672-1.573-5.245-.991-1.632-2.507-2.915-4.546-3.847-1.982-.99-4.4-1.486-7.256-1.486-4.546 0-8.189 1.195-10.928 3.585-2.739 2.33-4.225 5.536-4.458 9.615h-27.362c.233-6.178 2.098-11.656 5.595-16.435 3.555-4.837 8.479-8.596 14.773-11.277 6.294-2.68 13.58-4.02 21.856-4.02Zm78.465 15.936a31.342 31.342 0 0 1 3.148-4.92c2.797-3.556 6.206-6.267 10.227-8.132 4.022-1.923 8.538-2.884 13.55-2.884 7.518 0 14.046 1.952 19.582 5.857 5.537 3.905 9.792 9.529 12.764 16.872 2.972 7.285 4.458 15.94 4.458 25.964 0 9.965-1.516 18.62-4.546 25.963-3.031 7.285-7.372 12.879-13.025 16.784-5.595 3.905-12.151 5.857-19.669 5.857-5.012 0-9.5-.873-13.463-2.622-3.905-1.748-7.227-4.371-9.966-7.868a31.218 31.218 0 0 1-3.321-5.4v13.3