266-1.602-16.289-4.808-21.068-3.205-4.837-7.722-7.255-13.549-7.255Zm406.237-1.137c-3.905 0-7.343.962-10.316 2.885-2.914 1.865-5.187 4.662-6.819 8.392-.893 2.117-1.532 4.477-1.918 7.081h36.494c-.261-3.3-.917-6.156-1.969-8.567-1.34-3.264-3.321-5.712-5.944-7.344-2.622-1.631-5.799-2.447-9.528-2.447Z"></path><mask id="_R_55apicsmcdiv9felb_-b" width="124" height="126" x="0" y="0" maskUnits="userSpaceOnUse" style="mask-type:alpha"><path fill="url(#_R_55apicsmcdiv9felb_-a)" fill-rule="evenodd" d="M37.3.343c20.43 0 36.991 16.605 36.991 37.088v14.095h12.31c20.43 0 36.991 16.605 36.991 37.088s-16.561 37.088-36.99 37.088H.31V37.431C.31 16.948 16.87.343 37.3.343Z" clip-rule="evenodd"></path></mask><g mask="url(#_R_55apicsmcdiv9felb_-b)"><g filter="url(#_R_55apicsmcdiv9felb_-c)"><circle cx="54.389" cy="67.257" r="83.452" fill="#4B73FF"></circle></g><g filter="url(#_R_55apicsmcdiv9felb_-d)"><ellipse cx="63.557" cy="21.462" fill="#FF66F4" rx="106.879" ry="83.452"></ellipse></g><g filter="url(#_R_55apicsmcdiv9felb_-e)"><ellipse cx="80.992" cy="5.757" fill="#FF0105" rx="83.452" ry="73.289"></ellipse></g><g filter="url(#_R_55apicsmcdiv9felb_-f)"><circle cx="65.043" cy="21.442" r="50.188" fill="#FE7B02"></circle></g></g><defs><filter id="_R_55apicsmcdiv9felb_-c" width="241.704" height="241.704" x="-66.463" y="-53.596" color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse"><feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood><feBlend in="SourceGraphic" in2="BackgroundImageFix" result="shape"></feBlend><feGaussianBlur result="effect1_foregroundBlur" stdDeviation="18.7"></feGaussianBlur></filter><filter id="_R_55apicsmcdiv9felb_-d" width="288.559" height="241.704" x="-80.723" y="-99.39" color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse"><feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood><feBlend in="SourceGraphic" in2="BackgroundImageFix" result="shape"></feBlend><feGaussianBlur result="effect1_foregroundBlur" stdDeviation="18.7"></feGaussianBlur></filter><filter id="_R_55apicsmcdiv9felb_-e" width="241.704" height="221.378" x="-39.86" y="-104.931" color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse"><feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood><feBlend in="SourceGraphic" in2="BackgroundImageFix" result="shape"></feBlend><feGaussianBlur result="effect1_foregroundBlur" stdDeviation="18.7"></feGaussianBlur></filter><filter id="_R_55apicsmcdiv9felb_-f" width="175.176" height="175.176" x="-22.545" y="-66.146" color-interpolation-filters="sRGB" filterUnits="userSpaceOnUse"><feFlood flood-opacity="0" result="BackgroundImageFix"></feFlood><feBlend in="SourceGraphic" in2="BackgroundImageFix" result="shape"></feBlend><feGaussianBlur result="effect1_foregroundBlur" stdDeviation="18.7"></feGaussianBlur></filter><linearGradient id="_R_55apicsmcdiv9felb_-a" x1="41.797" x2="79.356" y1="22.372" y2="125.655" gradientUnits="userSpaceOnUse"><stop offset=".025" stop-color="#FF8E63"></stop><stop offset=".56" stop-color="#FF7EB0"></stop><stop offset=".95" stop-color="#4B73FF"></stop></linearGradient></defs></svg>
          </a>
        </div>

        <!-- Hero -->
        <div class="px-8 pb-6 text-center">
          <h1 class="text-2xl sm:text-3xl font-black leading-tight mb-3" style="color: #ffffff;">
            Deine 100 Lovable Credits warten!
          </h1>
          <p class="leading-relaxed text-sm sm:text-base" style="color: rgba(255,255,255,0.6);">
            Unser Partner <a href="https://lovable.dev" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.9); font-weight:600; text-decoration:none;">Lovable</a>
            ermöglicht jedem Teilnehmer,
            <span style="color: #F97316; font-weight:600;">100 kostenlose Credits zu erhalten</span> —
            damit du am {event.date} direkt loslegen kannst.
          </p>
        </div>

        <!-- Divider -->
        <div style="height:1px; background: rgba(255,255,255,0.08); margin: 0 2rem;"></div>

        <!-- Form -->
        <div id="form-section" class="px-8 py-6">
          <form id="optin-form" novalidate data-event={eventSlug}>
            <div class="flex flex-col gap-4">

              <div>
                <label for="name" class="block text-sm font-medium mb-1.5" style="color: rgba(255,255,255,0.75);">
                  Name
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  autocomplete="name"
                  required
                  placeholder="Vorname Nachname"
                  class="input-dark w-full px-4 py-3 rounded-xl text-base"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium mb-1.5" style="color: rgba(255,255,255,0.75);">
                  E-Mail
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  required
                  placeholder="deine@email.at"
                  class="input-dark w-full px-4 py-3 rounded-xl text-base"
                />
              </div>

              <label class="flex items-start gap-3 cursor-pointer">
                <input
                  id="consent"
                  name="consent"
                  type="checkbox"
                  class="mt-0.5 w-5 h-5 rounded cursor-pointer flex-shrink-0"
                  style="accent-color: #F97316;"
                />
                <span class="text-sm leading-snug" style="color: rgba(255,255,255,0.5);">
                  Ich willige ein, dass meine E-Mail-Adresse an
                  <a href="https://lovable.dev" target="_blank" rel="noopener noreferrer" style="color: rgba(255,255,255,0.8); font-weight:500; text-decoration:none;">Lovable</a> weitergegeben wird,
                  damit ich 100 Lovable Credits erhalten kann.
                </span>
              </label>

              <p id="error-msg" class="text-sm hidden" style="color: #ff7b7b;"></p>

              <button
                id="submit-btn"
                type="submit"
                disabled
                class="w-full py-3.5 rounded-xl font-semibold text-white transition-all text-base"
                style="background: #F97316; opacity: 0.4; cursor: not-allowed;"
              >
                <span id="btn-label">Credits sichern →</span>
                <span id="btn-spinner" class="hidden">
                  <svg class="inline w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                </span>
              </button>

            </div>
          </form>
        </div>

        <!-- Success State -->
        <div id="success-section" class="hidden px-8 py-10 text-center">
          <div class="text-5xl mb-4">🎉</div>
          <h2 class="text-xl font-bold mb-2" style="color: #ffffff;">Alles klar!</h2>
          <p style="color: rgba(255,255,255,0.6);" class="leading-relaxed">
            Du bekommst deine Credits rechtzeitig vor dem Event — schau in dein Postfach.
          </p>
        </div>

      </div>
    )}

    <!-- Footer -->
    <p class="mt-6 text-sm text-center" style="color: rgba(255,255,255,0.35);">
      Ein Event von
      <a href="https://lu.ma/genai-collective" target="_blank" rel="noopener noreferrer"
         style="color: #F97316;" class="font-medium hover:underline">
        AI Collective Innsbruck
      </a>
      {event && <span> · {event.date}</span>}
    </p>

  </main>
</BaseLayout>

<style>
  /* Override body background for this page only */
  body {
    background: #0e0f14 !important;
  }

  /* Lovable-style dark gradient background */
  .lovable-bg {
    background:
      radial-gradient(ellipse 80% 60% at 75% -10%, rgba(75, 115, 255, 0.45) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 20% 55%, rgba(201, 38, 211, 0.35) 0%, transparent 55%),
      radial-gradient(ellipse 50% 40% at 60% 105%, rgba(254, 123, 2, 0.4) 0%, transparent 55%),
      #0e0f14;
  }

  /* Glass morphism card */
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Dark input fields */
  .input-dark {
    background: rgba(255, 255, 255, 0.07);
    border: 1.5px solid rgba(255, 255, 255, 0.12);
    color: #ffffff;
    outline: none;
    transition: border-color 200ms ease;
  }
  .input-dark::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }
  .input-dark:focus {
    border-color: #F97316;
  }

  /* Submit button active state */
  #submit-btn:not(:disabled) {
    opacity: 1 !important;
    cursor: pointer !important;
  }
  #submit-btn:not(:disabled):hover {
    background: #EA6A0A !important;
  }

  /* Focus ring on dark */
  :focus-visible {
    outline: 2px solid #F97316 !important;
    outline-offset: 3px;
  }
</style>

<script>
  const form = document.getElementById('optin-form') as HTMLFormElement | null;
  if (!form) throw new Error('no form');

  const consent = document.getElementById('consent') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnLabel = document.getElementById('btn-label')!;
  const btnSpinner = document.getElementById('btn-spinner')!;
  const errorMsg = document.getElementById('error-msg')!;
  const formSection = document.getElementById('form-section')!;
  const successSection = document.getElementById('success-section')!;

  const eventSlug = form.dataset.event ?? '';

  consent.addEventListener('change', () => {
    submitBtn.disabled = !consent.checked;
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();

    if (!name || !email) {
      errorMsg.textContent = 'Bitte fülle alle Felder aus.';
      errorMsg.classList.remove('hidden');
      return;
    }

    btnLabel.classList.add('hidden');
    btnSpinner.classList.remove('hidden');
    submitBtn.disabled = true;

    try {
      const res = await fetch('/api/optin/lovable', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, consent: true, event: eventSlug }),
      });

      const data = await res.json();

      if (data.duplicate) {
        formSection.classList.add('hidden');
        successSection.innerHTML = `
          <div style="font-size:3rem;" class="mb-4">👍</div>
          <h2 class="text-xl font-bold mb-2" style="color:#ffffff;">Du bist schon dabei!</h2>
          <p style="color:rgba(255,255,255,0.6);" class="leading-relaxed">
            Du hast dich schon eingetragen — alles gut! Die Credits kommen rechtzeitig per E-Mail.
          </p>
        `;
        successSection.classList.remove('hidden');
        return;
      }

      if (data.success) {
        formSection.classList.add('hidden');
        successSection.classList.remove('hidden');
        return;
      }

      errorMsg.textContent = 'Etwas ist schiefgelaufen. Bitte versuch es nochmal.';
      errorMsg.classList.remove('hidden');
    } catch {
      errorMsg.textContent = 'Netzwerkfehler. Bitte versuch es nochmal.';
      errorMsg.classList.remove('hidden');
    } finally {
      btnLabel.classList.remove('hidden');
      btnSpinner.classList.add('hidden');
      submitBtn.disabled = !consent.checked;
    }
  });
</script>
