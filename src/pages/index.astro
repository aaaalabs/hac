---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EventCard from '../components/EventCard.astro';
import { loadAllEvents } from '../lib/events';

const events = await loadAllEvents();
---

<BaseLayout
  title="hac.kinn.tirol - Prototypen aus AI Collective Innsbruck"
  description="Schau was Leute in 4 Stunden mit KI bauen. Prototypen aus AI Collective Innsbruck Events - ausprobieren und voten."
>
  <!-- Non-dismissable modal -->
  <div id="aic-modal" style="position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);background:rgba(0,0,0,0.55);">
    <div style="width:min(960px,95vw);height:min(680px,90vh);border-radius:1rem;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.4);background:#fff;">
      <iframe
        src="https://www.aicollective.com/chapters/innsbruck"
        style="width:100%;height:100%;border:none;"
        loading="eager"
        title="AI Collective Innsbruck"
      ></iframe>
    </div>
  </div>

  <Header />
  <main id="main-content" class="max-w-[1200px] mx-auto px-4 sm:px-6 py-8 sm:py-12">

    <!-- Hero -->
    <div class="mb-8 sm:mb-12">
      <h1 class="text-4xl sm:text-5xl font-black text-[var(--dark-2)] leading-tight">
        Schau was Leute<br class="hidden sm:block" />
        in 4 Stunden bauen.
      </h1>
      <p class="mt-4 text-lg text-[var(--text-muted)] max-w-2xl leading-relaxed">
        Prototypen aus AI Collective
        <span class="text-[var(--orange)] font-semibold">Innsbruck</span>
        Events - gebaut mit KI, bewertet von der Community.
      </p>
    </div>

    <!-- Event-Liste -->
    {events.length === 0 ? (
      <div class="text-center py-24 text-[var(--text-muted)]">
        <p class="text-xl font-medium mb-2">Noch keine Events.</p>
        <p class="mb-6">Das erste kommt bald - bleib dran!</p>
        <a
          href="https://lu.ma/aic-innsbruck"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white"
          style="background: var(--orange);"
        >
          Zum nächsten Event →
        </a>
      </div>
    ) : (
      <div class="flex flex-col gap-4">
        {events.map(event => <EventCard event={event} />)}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
